CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/SCCameraKit" "${PODS_ROOT}/SCCameraKitBaseExtension" "${PODS_ROOT}/SCCameraKitLoginKitAuth" "${PODS_ROOT}/SCCameraKitPushToDeviceExtension" "${PODS_ROOT}/SnapSDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SCCameraKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SCCameraKitBaseExtension" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SCCameraKitLoginKitAuth" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SCCameraKitPushToDeviceExtension" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SnapSDK/SCSDKCoreKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SnapSDK/SCSDKCreativeKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/SnapSDK/SCSDKLoginKit"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceSwiftUI/SCSDKCameraKitReferenceSwiftUI.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceUI/SCSDKCameraKitReferenceUI.modulemap"
OTHER_LDFLAGS = $(inherited) -framework "SCSDKCameraKit" -framework "SCSDKCameraKitBaseExtension" -framework "SCSDKCameraKitLoginKitAuth" -framework "SCSDKCameraKitPushToDeviceExtension" -framework "SCSDKCoreKit" -framework "SCSDKCreativeKit" -framework "SCSDKLoginKit"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceSwiftUI/SCSDKCameraKitReferenceSwiftUI.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceUI/SCSDKCameraKitReferenceUI.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceSwiftUI" "${PODS_CONFIGURATION_BUILD_DIR}/SCCameraKitReferenceUI"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
